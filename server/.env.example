# Server — local development (copy to .env; never commit .env)
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000

# PostgreSQL — local Docker or Homebrew
DATABASE_URL=postgresql://keffirooms:keffirooms@localhost:5432/keffirooms

# JWT — generate: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-run-openssl-rand-base64-48
JWT_REFRESH_SECRET=change-me-run-openssl-rand-base64-48
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Google OAuth (optional locally — dev email sign-in used when empty)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
GOOGLE_DEV_LOGIN=true

# Admin seed (first migrate + seed only)
ADMIN_EMAIL=keffirooms@gmail.com
ADMIN_PASSWORD=ChangeThisSecurePassword123!
ADMIN_NAME=KeffiRooms Admin
ADMIN_PHONE=07066068160

ADMIN_WA=2347066068160
ADMIN_PHONE_DISPLAY=07066068160

# Cloudinary — optional locally (falls back to server/uploads/)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_LISTING_FOLDER=keffirooms/listings
MAX_FILE_SIZE_MB=10

# Gmail App Password — https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=keffirooms@gmail.com
SMTP_PASS=
EMAIL_FROM=keffirooms@gmail.com
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5
