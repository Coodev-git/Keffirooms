# ═══════════════════════════════════════════════════════════════
# KeffiRooms — PRODUCTION environment template
# Copy these variables to your hosting provider (Render, Railway, etc.)
# Do NOT commit real secrets to GitHub.
# ═══════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=3000

# Your live site URL (must be HTTPS)
APP_URL=https://your-domain.com
CLIENT_URL=https://your-domain.com

# Hosted PostgreSQL — Neon recommended (include sslmode=require)
# Example: postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Generate: openssl rand -base64 48  (run twice — use different values)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Google OAuth — https://console.cloud.google.com/apis/credentials
# JavaScript origins: https://your-domain.com
# Redirect URI: https://your-domain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-domain.com/api/auth/google/callback
GOOGLE_DEV_LOGIN=false

# Admin (seeded on first deploy — change password before going live)
ADMIN_EMAIL=your-admin@gmail.com
ADMIN_PASSWORD=
ADMIN_NAME=KeffiRooms Admin
ADMIN_PHONE=07000000000

# Platform WhatsApp coordination
ADMIN_WA=2347000000000
ADMIN_PHONE_DISPLAY=07000000000

# Cloudinary — required for listing photos in production
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_LISTING_FOLDER=keffirooms/listings
MAX_FILE_SIZE_MB=10

# Gmail SMTP — App Password for admin OTP & password reset
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-admin@gmail.com
SMTP_PASS=
EMAIL_FROM=your-admin@gmail.com
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5
