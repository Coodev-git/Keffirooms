{
  "name": "keffirooms-server",
  "version": "1.0.0",
  "description": "KeffiRooms production API — NSUK student housing platform",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "postinstall": "prisma generate",
    "db:migrate": "node src/db/migrate.js",
    "db:seed": "node src/db/seed.js",
    "prisma:generate": "prisma generate",
    "prod:check": "NODE_ENV=production node scripts/prod-check.js",
    "test:smtp": "node scripts/test-smtp.js",
    "test:reset-email": "node scripts/test-reset-email.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.6.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.1",
    "uuid": "^11.0.5",
    "@prisma/adapter-pg": "^6.9.0"
  },
  "devDependencies": {
    "prisma": "^6.9.0"
  }
}
